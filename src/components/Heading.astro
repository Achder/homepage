---
type Props = {
    type: keyof Pick<astroHTML.JSX.DefinedIntrinsicElements, 'h1' | 'h2' | 'h3' | 'h4'>
    class?: string
}

const { class: className, type: Type, ...rest } = Astro.props
---

<Type
    {...rest}
    class:list={[
        'm-0 italic font-black leading-[0.8] text-balance text-white text-shadow-lg/10 font-fraunces',
        {
            'text-7xl': Type === 'h1',
            'text-6xl ': Type === 'h2',
            'text-2xl': Type === 'h3',
        },
        className,
    ]}
>
    <slot />
</Type>
