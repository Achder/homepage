---
import Close from './icons/Close.astro'
---

<div
    id="lightbox"
    class="invisible fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4 opacity-0 transition-opacity duration-200 sm:p-10"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
>
    <button
        id="lightbox-close"
        type="button"
        class="absolute right-4 top-4 z-10 grid place-items-center rounded-full bg-white/10 p-2 text-white transition-colors hover:bg-white/20"
        aria-label="Close"
    >
        <Close />
    </button>

    <button
        id="lightbox-prev"
        type="button"
        class="absolute left-2 z-10 grid size-12 place-items-center rounded-full bg-white/10 text-3xl text-white transition-colors hover:bg-white/20 sm:left-6"
        aria-label="Previous image"
    >
        ‹
    </button>

    <img
        id="lightbox-image"
        class="max-h-full max-w-full rounded-sm object-contain shadow-2xl"
        alt=""
    />

    <button
        id="lightbox-next"
        type="button"
        class="absolute right-2 z-10 grid size-12 place-items-center rounded-full bg-white/10 text-3xl text-white transition-colors hover:bg-white/20 sm:right-6"
        aria-label="Next image"
    >
        ›
    </button>
</div>

<script>
    const lightbox = document.getElementById('lightbox')
    const imageEl = document.getElementById('lightbox-image') as HTMLImageElement | null
    const items = Array.from(document.querySelectorAll<HTMLElement>('.gallery-item'))

    if (lightbox && imageEl && items.length > 0) {
        let current = 0

        const show = (index: number) => {
            current = (index + items.length) % items.length
            const img = items[current].querySelector('img')
            if (img) {
                imageEl.src = img.currentSrc || img.src
                imageEl.alt = img.alt
            }
        }

        const open = (index: number) => {
            show(index)
            lightbox.classList.remove('invisible', 'opacity-0')
            lightbox.classList.add('opacity-100')
            lightbox.setAttribute('aria-hidden', 'false')
            document.body.style.overflow = 'hidden'
        }

        const close = () => {
            lightbox.classList.add('invisible', 'opacity-0')
            lightbox.classList.remove('opacity-100')
            lightbox.setAttribute('aria-hidden', 'true')
            document.body.style.overflow = ''
        }

        const isOpen = () => !lightbox.classList.contains('invisible')

        items.forEach((item, index) => {
            item.addEventListener('click', () => open(index))
        })

        document.getElementById('lightbox-close')?.addEventListener('click', close)
        document.getElementById('lightbox-prev')?.addEventListener('click', (event) => {
            event.stopPropagation()
            show(current - 1)
        })
        document.getElementById('lightbox-next')?.addEventListener('click', (event) => {
            event.stopPropagation()
            show(current + 1)
        })

        lightbox.addEventListener('click', (event) => {
            if (event.target === lightbox || event.target === imageEl) close()
        })

        document.addEventListener('keydown', (event) => {
            if (!isOpen()) return
            if (event.key === 'Escape') close()
            if (event.key === 'ArrowRight') show(current + 1)
            if (event.key === 'ArrowLeft') show(current - 1)
        })
    }
</script>
