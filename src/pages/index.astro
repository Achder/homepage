---
import MePig from '../images/pig.jpg'
import One from '../images/1.webp'
import Two from '../images/2.webp'
import Three from '../images/3.webp'
import Smile from '../images/smile.webp'
import Cobra from '../images/cobra.webp'
import Ball from '../images/ball.webp'
import Code from '../images/code.jpeg'
import Easy from '../images/easy.jpeg'
import Hello from '../images/hello.jpeg'
import Pow from '../images/pow.jpeg'
import Dunes from '../images/dunes.jpg'
import Swirl from '../images/swirl.jpeg'
import Preview from '../components/Preview.astro'
import PageLayout from '../layouts/PageLayout.astro'
import LinkButton from '../components/LinkButton.astro'
import Heading from '../components/Heading.astro'
import About from '../components/About.astro'

const siteUrl = Astro.site?.toString() ?? 'https://meerpohl.dev'
const personSchema = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Thomas Meerpohl',
    url: siteUrl,
    jobTitle: 'Freelance JavaScript and TypeScript Developer',
    description:
        'Freelance JavaScript and TypeScript developer building websites, web applications, and cross-platform apps.',
    email: 'mailto:thomas.meerpohl@gmail.com',
    address: {
        '@type': 'PostalAddress',
        addressLocality: 'Dresden',
        addressCountry: 'DE',
    },
    sameAs: [
        'https://www.linkedin.com/in/thomas-meerpohl-0609b619b/',
        'https://bsky.app/profile/meerpohl.dev',
        'https://github.com/Achder',
        'https://www.freelancermap.de/profil/thomas-meerpohl',
    ],
    knowsAbout: ['JavaScript', 'TypeScript', 'React', 'NestJS', 'Astro', 'GraphQL', 'Nx', 'Docker'],
})
---

<PageLayout
    title="Freelance JavaScript And TypeScript Developer In Dresden | Thomas Meerpohl"
    description="Thomas Meerpohl is a freelance JavaScript and TypeScript developer based in Dresden, Germany. He builds websites, web applications, and cross-platform apps."
    ogImagePath="/og/index.png"
    ogImageTarget="#profile"
    sectionPadding={false}
>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={personSchema} />
    </Fragment>

    <section
        class="grid w-full p-0 sm:p-10 lg:p-20 justify-items-start"
        style=`background-image: url(${MePig.src}); background-size: cover; background-position: center;`
    >
        <div class="grid gap-20 bg-brand sm:rounded-sm shadow-lg/30 shadow-black py-20 px-4 sm:px-10 max-w-3xl">
            <div class="contact grid justify-items-start content-end gap-8">
                <Heading type="h1" class="grid gap-2">
                    <p class="text-3xl text-shadow-lg/10 font-rethink font-black">Hi, I'm your freelance developer</p>
                    <p class="leading-none text-shadow-lg/10 font-rethink font-extrabold">Thomas Meerpohl</p>
                </Heading>
                <LinkButton href="mailto:thomas.meerpohl@gmail.com" class="text-2xl">Contact me</LinkButton>
            </div>

            <div class="grid gap-10 max-w-3xl contact">
                <About />
            </div>
        </div>
    </section>

    <section
        class="px-4 sm:px-10 grid gap-20 py-40 bg-dark justify-self-stretch grid-cols-[minmax(0,1fr)] overflow-clip"
    >
        <Heading type="h2">Gallery</Heading>

        <div
            class="grid justify-items-stretch sm:justify-items-center grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 w-full"
        >
            <Preview src={Cobra} class="gallery-image opacity-0" />
            <Preview src={One} class="gallery-image opacity-0" />
            <Preview src={Dunes} class="gallery-image opacity-0" />
            <Preview src={Pow} class="gallery-image opacity-0" />
            <Preview src={Ball} class="gallery-image opacity-0" />
            <Preview src={Easy} class="gallery-image opacity-0" />
            <Preview src={Smile} class="gallery-image opacity-0" />
            <Preview src={Three} class="gallery-image opacity-0" />
            <Preview src={Code} class="gallery-image opacity-0" />
            <Preview src={Two} class="gallery-image opacity-0" />
            <Preview src={Hello} class="gallery-image opacity-0" />
            <Preview src={Swirl} class="gallery-image opacity-0" />
        </div>
    </section>

    <script>
        import { fadeIn } from '../utils/animation'
        import { gsap, ScrollTrigger } from '../utils/gsap'

        fadeIn('.contact > *', '.contact', { startOffset: 50 })

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        const to: gsap.TweenVars = {
            opacity: 1,
            y: 0,
            filter: 'blur(0px) hue-rotate(0deg)',
        }

        if (prefersReducedMotion) {
            gsap.to('.gallery-image', to)
        } else {
            ScrollTrigger.batch('.gallery-image', {
                interval: 0.1,
                start: 'top bottom-=20px',
                once: true,
                onEnter(elements) {
                    gsap.fromTo(
                        elements,
                        {
                            opacity: 0,
                            y: '20%',
                            filter: 'blur(10px) hue-rotate(180deg)',
                        },
                        {
                            ...to,
                            duration: 0.5,
                            stagger: 0.3,
                            ease: 'power1.out',
                            grid: 'auto',
                        }
                    )
                },
            })
        }
    </script>
</PageLayout>
