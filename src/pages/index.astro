---
import MePig from '../images/pig.jpg'
import One from '../images/1.webp'
import Two from '../images/2.webp'
import Three from '../images/3.webp'
import Smile from '../images/smile.webp'
import Cobra from '../images/cobra.webp'
import Ball from '../images/ball.webp'
import Code from '../images/code.jpeg'
import Easy from '../images/easy.jpeg'
import Hello from '../images/hello.jpeg'
import Pow from '../images/pow.jpeg'
import Dunes from '../images/dunes.jpg'
import Swirl from '../images/swirl.jpeg'
import Preview from '../components/Preview.astro'
import Lightbox from '../components/Lightbox.astro'
import PageLayout from '../layouts/PageLayout.astro'
import LinkButton from '../components/LinkButton.astro'
import Heading from '../components/Heading.astro'
import About from '../components/About.astro'
import { Image } from 'astro:assets'
import FitTrackOg from '../images/fittrack-og.png'
import ChoChooseOg from '../images/chochoose-og.png'

const sideProjects = [
    {
        name: 'FitTrack',
        href: 'https://fit.meerpohl.dev',
        image: FitTrackOg,
        description:
            'A fitness tracker that uses AI to create personalized training plans based on your goals and fitness level, then lets you keep up the streak with simple checklists.',
    },
    {
        name: 'cho-choose',
        href: 'https://chochoose.meerpohl.dev',
        image: ChoChooseOg,
        description:
            'A collaborative polling app for groups. Spin up a poll in seconds, share a link, and let everyone rate the options until the best choice rises to the top.',
    },
]

const siteUrl = Astro.site?.toString() ?? 'https://meerpohl.dev'
const personSchema = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Thomas Meerpohl',
    url: siteUrl,
    jobTitle: 'Freelance JavaScript and TypeScript Developer',
    description:
        'Freelance JavaScript and TypeScript developer building websites, web applications, and cross-platform apps.',
    email: 'mailto:thomas.meerpohl@gmail.com',
    address: {
        '@type': 'PostalAddress',
        addressLocality: 'Dresden',
        addressCountry: 'DE',
    },
    sameAs: [
        'https://www.linkedin.com/in/thomas-meerpohl-0609b619b/',
        'https://bsky.app/profile/meerpohl.dev',
        'https://github.com/Achder',
        'https://www.freelancermap.de/profil/thomas-meerpohl',
    ],
    knowsAbout: ['JavaScript', 'TypeScript', 'React', 'NestJS', 'Astro', 'GraphQL', 'Nx', 'Docker'],
})
---

<PageLayout
    title="Freelance JavaScript And TypeScript Developer In Dresden | Thomas Meerpohl"
    description="Thomas Meerpohl is a freelance JavaScript and TypeScript developer based in Dresden, Germany. He builds websites, web applications, and cross-platform apps."
    ogImagePath="/og/index.png"
    ogImageTarget="#profile"
    sectionPadding={false}
>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={personSchema} />
    </Fragment>

    <section
        class="relative grid w-full p-0 sm:p-10 lg:p-20 justify-items-start"
        style=`background-image: url(${MePig.src}); background-size: cover; background-position: center;`
    >
        <div
            class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,rgba(0,0,0,0.8)_0%,rgba(0,0,0,0)_45%)]"
            aria-hidden="true"
        >
        </div>
        <div
            class="relative z-10 grid gap-20 bg-brand sm:rounded-sm shadow-lg/30 shadow-black py-20 px-4 sm:px-10 max-w-3xl"
        >
            <div class="contact grid justify-items-start content-end gap-8">
                <h1 class="font-black leading-[0.8] text-balance text-white text-shadow-lg/10">
                    <span class="block text-3xl text-shadow-lg/10 font-rethink font-black no-underline">
                        Hi, I'm your freelance webdeveloper
                    </span>
                    <span
                        class="block leading-none text-shadow-lg/10 font-rethink font-extrabold no-underline text-7xl"
                    >
                        Thomas Meerpohl
                    </span>
                </h1>
                <LinkButton href="mailto:thomas.meerpohl@gmail.com" class="text-2xl">Contact me</LinkButton>
            </div>

            <div class="grid gap-10 max-w-3xl contact">
                <About />
            </div>
        </div>
    </section>

    <section class="px-4 sm:px-10 grid gap-20 pt-40 bg-dark justify-self-stretch grid-cols-[minmax(0,1fr)]">
        <Heading type="h2">Side Projects</Heading>

        <div class="grid gap-10 grid-cols-1 lg:grid-cols-2 w-full">
            {
                sideProjects.map((project) => (
                    <a
                        href={project.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group grid content-start gap-6 bg-brand rounded-sm p-6 sm:p-8 shadow-lg/30 shadow-black transition duration-200 ease-out hover:scale-[1.01] hover:shadow-2xl/50"
                    >
                        <Image
                            src={project.image}
                            alt={`${project.name} preview`}
                            class="aspect-1200/630 w-full rounded-sm object-cover ring-1 ring-black/20"
                            loading="eager"
                        />
                        <Heading type="h3" class="not-italic font-rethink flex items-center gap-3">
                            {project.name}
                            <span
                                aria-hidden="true"
                                class="text-3xl leading-none transition-transform duration-200 group-hover:translate-x-1"
                            >
                                →
                            </span>
                        </Heading>
                        <p class="text-white">{project.description}</p>
                    </a>
                ))
            }
        </div>
    </section>

    <section
        class="px-4 sm:px-10 grid gap-20 py-40 bg-dark justify-self-stretch grid-cols-[minmax(0,1fr)] overflow-clip"
    >
        <Heading type="h2">Gallery</Heading>

        <div
            class="grid justify-items-stretch sm:justify-items-center grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 w-full"
        >
            <Preview src={Cobra} />
            <Preview src={One} />
            <Preview src={Dunes} />
            <Preview src={Pow} />
            <Preview src={Ball} />
            <Preview src={Easy} />
            <Preview src={Smile} />
            <Preview src={Three} />
            <Preview src={Code} />
            <Preview src={Two} />
            <Preview src={Hello} />
            <Preview src={Swirl} />
        </div>
    </section>

    <Lightbox />
</PageLayout>
