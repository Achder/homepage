---
import PageLayout from '../layouts/PageLayout.astro'
import Heading from '../components/Heading.astro'
import Timeline from '../components/Timeline.astro'
import TimelineEntry from '../components/TimelineEntry.astro'

const siteUrl = Astro.site?.toString() ?? 'https://meerpohl.dev/'
const pageUrl = new URL('what', siteUrl).toString()
const pageSchema = JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'BreadcrumbList',
            itemListElement: [
                {
                    '@type': 'ListItem',
                    position: 1,
                    name: 'Home',
                    item: siteUrl,
                },
                {
                    '@type': 'ListItem',
                    position: 2,
                    name: 'What I do',
                    item: pageUrl,
                },
            ],
        },
        {
            '@type': 'CollectionPage',
            url: pageUrl,
            name: 'JavaScript And TypeScript Projects',
            description:
                'Selected freelance and in-house JavaScript and TypeScript projects across React, NestJS, Nx monorepos, Docker, GraphQL, and cross-platform apps.',
            about: {
                '@type': 'Person',
                name: 'Thomas Meerpohl',
                url: siteUrl,
            },
        },
    ],
})
---

<PageLayout
    title="JavaScript And TypeScript Projects | Thomas Meerpohl"
    description="Selected freelance and in-house JavaScript and TypeScript projects across React, NestJS, Nx monorepos, Docker, GraphQL, and cross-platform apps."
    ogImagePath="/og/what.png"
>
    <Fragment slot="head">
        <script is:inline type="application/ld+json" set:html={pageSchema} />
    </Fragment>
    <div class="px-4 sm:px-10 grid gap-10 w-full max-w-350">
        <Heading type="h1" class="text-7xl">What I do</Heading>

        <Timeline>
            <TimelineEntry
                timerange="10.2025 - ongoing"
                title="IOT Plan"
                tech="ExpressJS, React, MaterialUI, MongoDB, Docker"
            >
                <p>Support migrating a legacy application to a modern tech stack.</p>
            </TimelineEntry>
            <TimelineEntry
                timerange="08.2025 - ongoing"
                title="Mercedes Benz GmbH"
                tech="Docker, NestJS, React, MaterialUI, React Hook Form, PNPM, GraphQl"
            >
                <p>
                    Support in the migration and consolidation of various services into a new microservice architecture.
                    Setup a PNPM monorepo with a docker compose based local development environment and micro-frontend
                    architecture. Write a React-Hook-Form and MaterialUI based form builder. Implement a custom window
                    management system inside the React application.
                </p>
            </TimelineEntry>
            <TimelineEntry
                timerange="02.2024 - ongoing"
                title="Racyics"
                tech="Nx Monorepo, Nestjs, GraphQl, AWS DynamoDB, React, TailwindCSS, Shadcn/UI"
            >
                <p>Developing a product management tool inspired by Jira.</p>
            </TimelineEntry>
            <TimelineEntry
                timerange="05.2024 - 07.2025"
                title="Girona GmbH"
                tech="React, MaterialUI, Tanstack Query, React Router"
            >
                <p>
                    Migrating a legacy React application to modern libraries and best practices. Replaced a custom
                    data-fetching solution by introducing Tanstack query for data fetching. Migrated Material UI from v4
                    to v6. Migrated React Router from v5 to v7.
                </p>
            </TimelineEntry>
            <TimelineEntry
                timerange="02.2024 - 03.2025"
                title="enerithm"
                tech="CapacitorJS, React, TailwindCSS, RadixUI, Framer Motion, Strapi"
            >
                <p>
                    Developing a cross-platform energy consultant app available on iOS, Android and the web using a
                    single codebase.
                </p>
            </TimelineEntry>

            <TimelineEntry timerange="12.2023 - 01.2024" title="Anvajo" tech="Vanilla JS, Nginx, Docker">
                <p>Implementing an on-device file-browser and -exporter for an embedded mobile medical device.</p>
            </TimelineEntry>

            <TimelineEntry timerange="12.2023" title="🚀 Official start working as a freelancer" />

            <TimelineEntry
                timerange="05.2022 - 11.2023"
                title="Mercedes-Benz Tech Innovation"
                tech="ASP.net, Vanilla JS, jQuery, Rx.js, Vue.js, Webpack"
            >
                <p>Implementing features and fixing bugs for an online vehicle booking system.</p>
                <p>Refactoring the main booking calendar from an Ember.js app to an Rx.js based solution.</p>
                <p>
                    Implementing a proof-of-concept for a micro-frontend architecture based on webpack module federation
                    and Vue.js.
                </p>
            </TimelineEntry>

            <TimelineEntry
                timerange="05.2020 - 04.2022"
                title="Anvajo"
                tech="Electron, React, Adobe Spectrum, Docker, Python"
            >
                <p>
                    Developing a desktop application for managing, previewing and exporting measurements on an embedded
                    mobile medical device.
                </p>
                <p>
                    Developing an internal desktop application for triggering and monitoring measurements on an embedded
                    prototype.
                </p>
            </TimelineEntry>

            <TimelineEntry timerange="09.2016 - 05.2020" title="Wave Casual" tech="C++, JUCE, Docker, React">
                <p>Developing the frontend and backend of a software synthesizer VST plugin.</p>
                <p>
                    Developing a smart volume meter on an embedded platform including a companion app for iOS and
                    Android
                </p>
                <p>Developing a crowdsourcing PWA application based on React</p>
            </TimelineEntry>
        </Timeline>
    </div>
</PageLayout>
